datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String
  address   String?
  phone     String?
  zone      String?
  points    Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  pickupRequestsAsUser   PickupRequest[]     @relation("UserPickups")
  pickupRequestsAsDriver PickupRequest[]     @relation("DriverPickups")
  inventories            Inventory[]
  transactions           Transaction[]
  voucherRedemptions     VoucherRedemption[]
}

model PickupRequest {
  id              Int      @id @default(autoincrement())
  userId          Int
  driverId        Int?
  wasteTypes      String   // Stored as JSON string
  estimatedWeight Float
  actualWeight    Float?
  status          String   @default("PENDING")
  address         String
  note            String?
  points          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation("UserPickups", fields: [userId], references: [id])
  driver       User?         @relation("DriverPickups", fields: [driverId], references: [id])
  transactions Transaction[]
}

model Inventory {
  id          Int             @id @default(autoincrement())
  tps3rId     Int
  commodity   String
  stockKg     Float
  pricePerKg  Float
  status      String @default("READY")
  createdAt   DateTime        @default(now())

  tps3r User @relation(fields: [tps3rId], references: [id])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  pickupId    Int?
  points      Int
  type        String // "EARN" | "REDEEM" | "DEDUCTION"
  description String
  createdAt   DateTime @default(now())

  user   User           @relation(fields: [userId], references: [id])
  pickup PickupRequest? @relation(fields: [pickupId], references: [id])
}

model VoucherRedemption {
  id          Int      @id @default(autoincrement())
  userId      Int
  voucherName String
  pointsUsed  Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
